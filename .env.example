# ChartSnap Environment Variables

# API URL (used by Telegram Bot to fetch charts)
API_URL=http://localhost:3000

# API Key (used by Telegram Bot)
# Use a PRO or ULTRA key from server/data/keys.json
API_KEY=demo-key-pro-001

# Telegram Bot Token (from @BotFather on Telegram)
# TELEGRAM_BOT_TOKEN=your_bot_token_here
